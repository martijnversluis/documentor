<% if party.contact_details? %>
  <dl class="space-y-2 text-sm">
    <% if party.phone.present? %>
      <div class="flex items-start gap-2">
        <svg class="w-4 h-4 mt-0.5 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
        </svg>
        <div class="min-w-0">
          <dt class="sr-only">Telefoon</dt>
          <dd class="break-all">
            <%= link_to party.phone, "tel:#{party.phone.gsub(/\s/, '')}", class: "text-blue-600 hover:underline" %>
          </dd>
        </div>
      </div>
    <% end %>

    <% if party.email.present? %>
      <div class="flex items-start gap-2">
        <svg class="w-4 h-4 mt-0.5 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
        </svg>
        <div class="min-w-0">
          <dt class="sr-only">E-mailadres</dt>
          <dd class="break-all">
            <%= link_to party.email, "mailto:#{party.email}", class: "text-blue-600 hover:underline" %>
          </dd>
        </div>
      </div>
    <% end %>

    <% if party.address.present? || party.postal_code.present? || party.city.present? %>
      <div class="flex items-start gap-2">
        <svg class="w-4 h-4 mt-0.5 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a2 2 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
        </svg>
        <div class="min-w-0">
          <dt class="sr-only">Adres</dt>
          <dd>
            <% if party.address.present? %><%= party.address %><br><% end %>
            <%= [party.postal_code, party.city].compact_blank.join(" ") %>
          </dd>
        </div>
      </div>
    <% end %>

    <% if party.website.present? %>
      <div class="flex items-start gap-2">
        <svg class="w-4 h-4 mt-0.5 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"></path>
        </svg>
        <div class="min-w-0">
          <dt class="sr-only">Website</dt>
          <dd class="break-all">
            <%= link_to party.website, party.website, target: "_blank", rel: "noopener", class: "text-blue-600 hover:underline" %>
          </dd>
        </div>
      </div>
    <% end %>
  </dl>
<% else %>
  <p class="text-sm text-gray-500">Geen contactgegevens ingevuld.</p>
<% end %>
