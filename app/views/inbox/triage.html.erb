<div class="max-w-4xl mx-auto">
  <div class="mb-6">
    <div class="flex items-center justify-between mb-2">
      <h1 class="text-2xl font-bold text-gray-900">Inbox Triage</h1>
      <%= link_to filter_inbox_action_items_path, class: "text-sm text-gray-500 hover:text-gray-700" do %>
        <span class="inline-flex items-center gap-1">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
          Sluiten
        </span>
      <% end %>
    </div>
    <p class="text-sm text-gray-500">Werk je inbox items één voor één af</p>
  </div>

  <%# Progress bar %>
  <div class="mb-8">
    <div class="flex items-center justify-between text-sm text-gray-600 mb-2">
      <span>Item <%= @current_index + 1 %> van <%= @total_count %></span>
      <span><%= @total_count %> items in inbox</span>
    </div>
    <div class="w-full bg-gray-200 rounded-full h-2">
      <div class="bg-blue-500 h-2 rounded-full transition-all duration-300" style="width: <%= ((@current_index + 1).to_f / @total_count * 100).round %>%"></div>
    </div>
  </div>

  <%# Current item card %>
  <div class="bg-white rounded-xl shadow-lg border border-gray-200 mb-6">
    <div class="p-6">
      <%# Item type badge and date %>
      <div class="flex items-center gap-2 mb-4">
        <% case @current_item %>
        <% when ActionItem %>
          <span class="inline-flex items-center px-2 py-1 rounded text-xs font-medium bg-orange-100 text-orange-700">Actiepunt</span>
        <% when Document %>
          <span class="inline-flex items-center px-2 py-1 rounded text-xs font-medium bg-blue-100 text-blue-700">Document</span>
        <% when Note %>
          <span class="inline-flex items-center px-2 py-1 rounded text-xs font-medium bg-green-100 text-green-700">Notitie</span>
        <% end %>
        <span class="text-sm text-gray-500"><%= time_ago_in_words(@current_item.created_at) %> geleden toegevoegd</span>
      </div>

      <%# Item content based on type %>
      <% case @current_item %>
      <% when ActionItem %>
        <div class="prose prose-lg max-w-none mb-4">
          <%= markdown(@current_item.description) %>
        </div>
        <% if @current_item.notes.present? %>
          <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mb-4">
            <div class="flex items-start gap-2">
              <svg class="w-5 h-5 text-amber-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
              </svg>
              <div class="prose prose-sm max-w-none text-amber-900">
                <%= markdown(@current_item.notes) %>
              </div>
            </div>
          </div>
        <% end %>
        <% if @current_item.due_date.present? %>
          <p class="text-sm <%= @current_item.overdue? ? 'text-red-600' : 'text-gray-500' %>">
            Deadline: <%= @current_item.due_date.strftime("%d-%m-%Y") %>
          </p>
        <% end %>

      <% when Document %>
        <h2 class="text-xl font-semibold text-gray-900 mb-2"><%= @current_item.name %></h2>
        <% if @current_item.file.attached? %>
          <p class="text-sm text-gray-500 mb-4">
            <%= number_to_human_size(@current_item.file.byte_size) %>
            · <%= @current_item.file.content_type %>
          </p>
        <% end %>

        <% if @duplicate %>
          <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mb-4">
            <p class="text-sm text-amber-700">
              <svg class="w-4 h-4 inline-block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"></path>
              </svg>
              Mogelijk duplicaat van
              <%= link_to @duplicate.name, @duplicate, class: "underline font-medium hover:text-amber-800" %>
              <% if @duplicate.dossier %>
                in <%= link_to @duplicate.dossier.name, @duplicate.dossier, class: "underline font-medium hover:text-amber-800" %>
              <% end %>
            </p>
          </div>
        <% end %>

        <%# Document viewer %>
        <% if @current_item.file.attached? %>
          <div class="border border-gray-200 rounded-lg overflow-hidden">
            <% if @current_item.file.content_type.start_with?("image/") %>
              <% if @current_item.file.content_type.in?(%w[image/heic image/heif]) %>
                <%= image_tag @current_item.file.variant(format: :jpeg), class: "max-w-full h-auto" %>
              <% else %>
                <%= image_tag @current_item.file, class: "max-w-full h-auto" %>
              <% end %>
            <% elsif @current_item.file.content_type.start_with?("video/") %>
              <video controls class="max-w-full h-auto" poster="<%= url_for(@current_item.file.preview(resize_to_limit: [1280, 720])) %>">
                <source src="<%= rails_service_blob_proxy_path(@current_item.file.signed_id, @current_item.file.filename) %>" type="<%= @current_item.file.content_type == 'video/quicktime' ? 'video/mp4' : @current_item.file.content_type %>">
              </video>
            <% elsif @current_item.file.content_type == "application/pdf" %>
              <iframe src="<%= rails_blob_path(@current_item.file, disposition: "inline") %>" class="w-full h-[600px]"></iframe>
            <% elsif @current_item.file.content_type == "text/plain" %>
              <pre class="whitespace-pre-wrap text-sm text-gray-800 font-mono bg-gray-50 p-4 overflow-x-auto"><%= @current_item.file.download.force_encoding("UTF-8") %></pre>
            <% elsif @current_item.file.content_type == "message/rfc822" || @current_item.file.filename.to_s.end_with?(".eml") %>
              <% eml = parse_eml(@current_item.file) %>
              <div class="p-4 space-y-4">
                <div class="grid grid-cols-[auto_1fr] gap-x-4 gap-y-2 text-sm border-b border-gray-200 pb-4">
                  <% if eml[:from].present? %>
                    <span class="font-medium text-gray-500">Van:</span>
                    <span class="text-gray-900"><%= eml[:from] %></span>
                  <% end %>
                  <% if eml[:to].present? %>
                    <span class="font-medium text-gray-500">Aan:</span>
                    <span class="text-gray-900"><%= eml[:to] %></span>
                  <% end %>
                  <% if eml[:subject].present? %>
                    <span class="font-medium text-gray-500">Onderwerp:</span>
                    <span class="text-gray-900 font-medium"><%= eml[:subject] %></span>
                  <% end %>
                </div>
                <div class="prose max-w-none">
                  <%= sanitize eml[:body], tags: %w[p br div span a b i u strong em ul ol li h1 h2 h3 h4 h5 h6 table tr td th thead tbody blockquote pre code img hr], attributes: %w[href src alt class style] %>
                </div>
              </div>
            <% else %>
              <div class="text-center py-8">
                <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                </svg>
                <p class="mt-2 text-sm text-gray-500">Preview niet beschikbaar</p>
                <p class="text-xs text-gray-400"><%= @current_item.file.content_type %></p>
              </div>
            <% end %>
          </div>
        <% end %>

      <% when Note %>
        <h2 class="text-xl font-semibold text-gray-900 mb-4"><%= @current_item.title %></h2>
        <% if @current_item.content.present? %>
          <div class="prose max-w-none">
            <%= markdown(@current_item.content) %>
          </div>
        <% end %>
      <% end %>
    </div>

    <%# Assign to dossier %>
    <div class="border-t border-gray-100 px-6 py-4">
      <label class="block text-sm font-medium text-gray-700 mb-2">Toewijzen aan dossier</label>
      <% assign_url = case @current_item
                       when ActionItem then assign_action_item_path(@current_item)
                       when Document then assign_document_path(@current_item)
                       when Note then assign_note_path(@current_item)
                       end %>
      <% next_item = @all_items[(@current_index + 1) % @total_count] if @total_count > 1 %>
      <% next_path = next_item ? inbox_triage_path(item_id: item_identifier(next_item)) : filter_inbox_action_items_path %>
      <%= form_with url: assign_url, method: :patch, data: { controller: "auto-submit", turbo: false } do |f| %>
        <%= f.hidden_field :redirect_to, value: next_path %>
        <%= render "shared/dossier_select",
                   field_name: "dossier_id",
                   selected_id: nil,
                   include_blank: "Kies dossier...",
                   auto_submit: true,
                   input_class: "w-full max-w-md",
                   show_all: true %>
      <% end %>
    </div>

    <%# Action buttons %>
    <div class="bg-gray-50 px-6 py-4 flex items-center justify-between">
      <div class="flex items-center gap-2">
        <% if @current_index > 0 %>
          <% prev_item = @all_items[@current_index - 1] %>
          <%= link_to inbox_triage_path(item_id: item_identifier(prev_item)), class: "inline-flex items-center gap-1 px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
            </svg>
            Vorige
          <% end %>
        <% end %>
        <% if @current_index < @total_count - 1 %>
          <% next_item = @all_items[@current_index + 1] %>
          <%= link_to inbox_triage_path(item_id: item_identifier(next_item)), class: "inline-flex items-center gap-1 px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50" do %>
            Volgende
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          <% end %>
        <% end %>
      </div>

      <div class="flex items-center gap-2">
        <% case @current_item %>
        <% when ActionItem %>
          <%= link_to edit_action_item_path(@current_item, return_to: inbox_triage_path(item_id: item_identifier(@current_item))), class: "inline-flex items-center gap-1 px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
            </svg>
            Bewerken
          <% end %>
        <% when Document %>
          <%= link_to edit_document_path(@current_item), class: "inline-flex items-center gap-1 px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
            </svg>
            Bewerken
          <% end %>
        <% when Note %>
          <%= link_to edit_note_path(@current_item), class: "inline-flex items-center gap-1 px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
            </svg>
            Bewerken
          <% end %>
        <% end %>

        <% delete_url = case @current_item
                        when ActionItem then action_item_path(@current_item)
                        when Document then document_path(@current_item)
                        when Note then note_path(@current_item)
                        end %>
        <% next_after_delete = @all_items[@current_index + 1] || @all_items[@current_index - 1] %>
        <% redirect_after_delete = next_after_delete ? inbox_triage_path(item_id: item_identifier(next_after_delete)) : filter_inbox_action_items_path %>
        <%= button_to delete_url, method: :delete, params: { redirect_to: redirect_after_delete }, class: "inline-flex items-center gap-1 px-4 py-2 text-sm font-medium text-red-600 bg-white border border-red-300 rounded-lg hover:bg-red-50", data: { turbo: false, confirm: "Weet je zeker dat je dit item wilt verwijderen?" } do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
          </svg>
          Verwijderen
        <% end %>
      </div>
    </div>
  </div>

  <%# All items overview %>
  <div class="bg-white rounded-lg shadow-sm border border-gray-200">
    <div class="px-4 py-3 border-b border-gray-100">
      <h2 class="font-semibold text-gray-700">Alle inbox items (<%= @total_count %>)</h2>
    </div>
    <ul class="divide-y divide-gray-100">
      <% @all_items.each_with_index do |item, index| %>
        <li class="px-4 py-3 flex items-center gap-3 <%= item == @current_item ? 'bg-blue-50' : '' %>">
          <% if item == @current_item %>
            <div class="w-5 h-5 rounded-full bg-blue-500 flex items-center justify-center flex-shrink-0">
              <span class="text-xs text-white font-medium"><%= index + 1 %></span>
            </div>
          <% else %>
            <div class="w-5 h-5 rounded-full bg-gray-200 flex items-center justify-center flex-shrink-0">
              <span class="text-xs text-gray-500"><%= index + 1 %></span>
            </div>
          <% end %>

          <% type_label, type_color = case item
                                      when ActionItem then ["AP", "text-orange-600 bg-orange-50"]
                                      when Document then ["DOC", "text-blue-600 bg-blue-50"]
                                      when Note then ["NOT", "text-green-600 bg-green-50"]
                                      end %>
          <span class="text-[10px] font-medium px-1.5 py-0.5 rounded <%= type_color %> flex-shrink-0"><%= type_label %></span>

          <%= link_to inbox_triage_path(item_id: item_identifier(item)), class: "flex-1 min-w-0 overflow-hidden text-sm #{'font-medium text-blue-700' if item == @current_item} #{'text-gray-600' unless item == @current_item} hover:underline" do %>
            <div class="truncate">
              <% case item %>
              <% when ActionItem %>
                <%= strip_tags(markdown(item.description)).squish.truncate(60) %>
              <% when Document %>
                <%= item.name.truncate(60) %>
              <% when Note %>
                <%= item.title.truncate(60) %>
              <% end %>
            </div>
          <% end %>
          <span class="text-xs text-gray-400 flex-shrink-0"><%= time_ago_in_words(item.created_at) %></span>
        </li>
      <% end %>
    </ul>
  </div>
</div>
