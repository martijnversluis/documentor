<div id="dossier-next-actions">
  <% next_items = dossier.action_items.pending.next_actions.root_items.ordered %>
  <% if next_items.any? %>
    <div class="bg-amber-50 rounded-lg shadow-sm border border-amber-200">
      <div class="p-4 border-b border-amber-200">
        <h2 class="font-semibold text-amber-900 flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 5l7 7-7 7M5 5l7 7-7 7"></path>
          </svg>
          Eerstvolgende acties
        </h2>
      </div>
      <div class="p-4">
        <ul class="-mx-3">
          <% next_items.each do |item| %>
            <%= render "action_items/action_item", action_item: item, link_to_dossier: false %>
          <% end %>
        </ul>
      </div>
    </div>
  <% end %>
</div>
