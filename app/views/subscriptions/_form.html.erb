<%# locals: (subscription:) %>
<%= form_with model: subscription, class: "space-y-4" do |f| %>
  <% if subscription.errors.any? %>
    <div class="mb-4 bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg">
      <ul class="list-disc list-inside">
        <% subscription.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name, "Naam", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :name, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent", placeholder: "Bijv: Netflix, Zorgverzekering, Huurcontract...", autofocus: true %>
  </div>

  <div>
    <%= f.label :reference, "Referentie", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :reference, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent", placeholder: "Contractnummer, polisnummer, klantnummer..." %>
  </div>

  <div>
    <%= f.label :description, "Beschrijving", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_area :description, rows: 3, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent", placeholder: "Optionele beschrijving...", data: { controller: "markdown-paste" } %>
    <p class="mt-1 text-xs text-gray-500">Markdown ondersteund</p>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div>
      <%= f.label :cost, "Bedrag", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.number_field :cost, step: 0.01, min: 0, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent", placeholder: "Bijv: 9,99" %>
    </div>

    <div>
      <%= f.label :cost_frequency, "Betaalinterval", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.select :cost_frequency, [
        ["Per 2 weken", "biweekly"],
        ["Per maand", "monthly"],
        ["Per kwartaal", "quarterly"],
        ["Per jaar", "yearly"],
        ["Eenmalig", "one_time"]
      ], { include_blank: "" }, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
    </div>
  </div>

  <div>
    <%= f.label :contract_duration, "Contractduur", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.select :contract_duration, [
      ["Per maand", "monthly"],
      ["Per kwartaal", "quarterly"],
      ["Per jaar", "yearly"],
      ["Onbepaalde tijd", "indefinite"]
    ], { include_blank: "" }, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
    <p class="mt-1 text-xs text-gray-500">Hoe lang loopt het contract per termijn?</p>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div>
      <%= f.label :starts_on, "Ingangsdatum", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.date_field :starts_on, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
    </div>

    <div>
      <%= f.label :ends_on, "Einddatum", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.date_field :ends_on, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
      <p class="mt-1 text-xs text-gray-500">Leeg laten voor doorlopend</p>
    </div>
  </div>

  <div class="flex items-center gap-2">
    <%= f.check_box :auto_renew, class: "w-4 h-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500" %>
    <%= f.label :auto_renew, "Automatische verlenging", class: "text-sm font-medium text-gray-700" %>
  </div>

  <div>
    <%= f.label :portal_url, "Portaal URL", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.url_field :portal_url, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent", placeholder: "https://..." %>
  </div>

  <div>
    <label class="block text-sm font-medium text-gray-700 mb-1">Partij</label>
    <%= select_tag :party_id, options_from_collection_for_select(Party.ordered, :id, :name, subscription.parties.first&.id), include_blank: "Geen partij", class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
  </div>

  <div>
    <%= f.label :dossier_id, "Dossier", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.collection_select :dossier_id, Dossier.active.ordered_by_name, :id, :name, { include_blank: "Geen dossier" }, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
  </div>

  <div>
    <%= f.label :tag_list, "Tags", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :tag_list, class: "w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent", placeholder: "Gescheiden door komma's" %>
  </div>

  <div class="flex items-center gap-3 pt-4 border-t border-gray-200">
    <%= f.submit subscription.persisted? ? "Opslaan" : "Toevoegen", class: "px-4 py-2 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 cursor-pointer" %>
    <%= link_to "Annuleren", subscription.persisted? ? subscription : subscriptions_path, class: "px-4 py-2 text-gray-700 hover:text-gray-900" %>
  </div>
<% end %>
